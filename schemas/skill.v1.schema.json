{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/0xlucasliao/skills-hub/main/schemas/skill.v1.schema.json",
  "title": "Skill Manifest v1",
  "description": "Schema for a BNB Chain Skills Hub skill manifest (submission and published forms).",
  "type": "object",
  "required": ["name", "github_url", "category", "description"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "enum": ["1"],
      "description": "Manifest schema version. Always '1' for this schema."
    },
    "id": {
      "type": "string",
      "description": "Unique skill identifier. Must match the parent directory name.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable display name."
    },
    "github_url": {
      "type": "string",
      "pattern": "^https://github\\.com/[^/]+/[^/]+$",
      "description": "Public GitHub repository URL (https://github.com/owner/repo)."
    },
    "category": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "One or more tags describing the skill (e.g. [\"defi\", \"nft\"])."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "One or two sentences describing what the skill does and when to use it."
    },
    "interface": {
      "type": "object",
      "description": "Optional: machine-readable invocation contract (MCP tool definition, OpenAI function schema, or REST spec).",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["mcp", "openai-function", "rest"],
          "description": "Interface protocol type."
        },
        "definition": {
          "description": "The full interface definition object for the chosen type.",
          "oneOf": [
            { "type": "object" },
            { "type": "null" }
          ]
        }
      }
    },
    "publisher": {
      "type": "object",
      "description": "Auto-enriched: GitHub identity of the repository owner.",
      "required": ["username", "type", "profile_url"],
      "additionalProperties": false,
      "properties": {
        "username": { "type": "string" },
        "display_name": { "type": "string" },
        "type": { "type": "string", "enum": ["User", "Organization"] },
        "profile_url": { "type": "string" },
        "avatar_url": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "description": "Auto-enriched: source repository snapshot details.",
      "additionalProperties": false,
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Latest commit SHA at publish time."
        },
        "fetched_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the repo was fetched."
        }
      }
    },
    "repo": {
      "type": "object",
      "description": "Auto-enriched: GitHub repository metadata.",
      "additionalProperties": false,
      "properties": {
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "default_branch": {
          "type": "string"
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Auto-enriched: AgentGuard security scan results.",
      "additionalProperties": false,
      "properties": {
        "agentguard_scan_id": { "type": ["string", "null"] },
        "agentguard_report_url": { "type": ["string", "null"] },
        "agentguard_result": {
          "description": "Structured scan result from AgentGuard.",
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "risk_score": { "type": ["number", "null"] },
                "risk_level": {
                  "type": ["string", "null"],
                  "enum": ["safe", "low", "medium", "high", "critical", null]
                },
                "verdict": { "type": ["string", "null"] },
                "summary": { "type": ["string", "null"] },
                "threats": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Auto-enriched: ISO 8601 timestamp of first publication."
    }
  }
}
